# ── Docker-managed MySQL (default, 3-Container-Setup) ────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=isms
MYSQL_USER=isms_user
MYSQL_PASSWORD=isms_password

# ── External MySQL (Single-Container / externe DB) ───────────────────────────
# DATABASE_URL has priority over the DB_* variables above.
# Example: mysql://isms_user:password@192.168.1.100:3306/isms
# DATABASE_URL=mysql://user:password@host:3306/dbname

# ── Application ──────────────────────────────────────────────────────────────
# REQUIRED — the app refuses to start without these (no insecure fallback since
# v1.8.1). Generate strong random values, e.g.:  openssl rand -hex 32
# JWT_SECRET:     signs login tokens (use >= 32 random chars)
# ENCRYPTION_KEY: encrypts sensitive settings (OIDC client secret) in the DB
# SESSION_SECRET: session cookie secret (used during the OIDC login flow)
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here
SESSION_SECRET=your_session_secret_here

# Public URL of the app — REQUIRED for the OIDC callback to work.
APP_URL=http://localhost:8080

# Set to "true" when running behind an HTTPS reverse proxy.
# SECURE_COOKIES=false

# ── Passkeys / WebAuthn ──────────────────────────────────────────────────────
# Defaults work for localhost. In production set these to your domain:
#   WEBAUTHN_RP_ID  = hostname only, no scheme/port (e.g. isms.example.com)
#   WEBAUTHN_ORIGIN = full origin incl. scheme (e.g. https://isms.example.com)
# WEBAUTHN_RP_ID=
# WEBAUTHN_ORIGIN=

# ── Single Sign-On (OIDC) ────────────────────────────────────────────────────
# SSO is configured IN THE APP (no env vars): log in as admin →
# Administration → Single Sign-On. Works with any OIDC provider
# (Authentik, Keycloak, Microsoft Entra, Google, Zitadel, …).
# Redirect URI to register at the provider: <APP_URL>/api/auth/oidc/callback

# ── MCP Server (Model Context Protocol) ─────────────────────────────────────
# Optional static API key for MCP clients (Claude Desktop, Claude Code, etc.)
# If set:  Authorization: Bearer <MCP_SECRET>  grants admin-level MCP access.
# If not set: regular JWT tokens from /api/auth/login are used instead.
# Endpoint: POST/GET/DELETE <APP_URL>/mcp
# Generate: openssl rand -hex 32
# MCP_SECRET=your_mcp_secret_here

# ── GHCR image version (only for docker-compose.ghcr*.yml) ───────────────────
# ISMS_VERSION=latest
