{
  "name": "Main Branch Protection",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "~DEFAULT_BRANCH"
      ]
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": false,
        "required_reviewers": [],
        "require_code_owner_review": true,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false,
        "allowed_merge_methods": [
          "merge",
          "squash",
          "rebase"
        ]
      }
    },
    {
      "type": "code_scanning",
      "parameters": {
        "code_scanning_tools": [
          {
            "tool": "CodeQL",
            "security_alerts_threshold": "high_or_higher",
            "alerts_threshold": "errors"
          }
        ]
      }
    },
    {
      "type": "code_quality",
      "parameters": {
        "severity": "warnings"
      }
    },
    {
      "type": "copilot_code_review",
      "parameters": {
        "review_on_push": true,
        "review_draft_pull_requests": false
      }
    },
    {
      "type": "commit_author_email_pattern",
      "parameters": {
        "name": "Nur bekannte Autor-Domains",
        "negate": false,
        "operator": "regex",
        "pattern": "^.+@(herz\\.dev|users\\.noreply\\.github\\.com)$"
      }
    },
    {
      "type": "committer_email_pattern",
      "parameters": {
        "name": "Nur bekannte Committer-Domains",
        "negate": false,
        "operator": "regex",
        "pattern": "^.+@(herz\\.dev|users\\.noreply\\.github\\.com)$"
      }
    },
    {
      "type": "commit_message_pattern",
      "parameters": {
        "name": "Aussagekräftige Commit-Message (min. 10 Zeichen)",
        "negate": false,
        "operator": "regex",
        "pattern": "^.{10,}"
      }
    }
  ],
  "bypass_actors": [
    {
      "actor_id": null,
      "actor_type": "OrganizationAdmin",
      "bypass_mode": "always"
    },
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    },
    {
      "actor_id": 29110,
      "actor_type": "Integration",
      "bypass_mode": "always"
    },
    {
      "actor_id": 946600,
      "actor_type": "Integration",
      "bypass_mode": "always"
    }
  ]
}
